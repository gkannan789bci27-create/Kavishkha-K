#include <stdio.h>

int main() {
    int n, count = 0;
    printf("Enter an integer: ");
    scanf("%d", &n);

    while (n > 0) {
        // n & 1 checks if the last bit is 1
        count += n & 1;
        // Shift bits to the right by one position
        n >>= 1;
    }

    printf("Number of set bits (1s): %d\n", count);
    return 0;
}
