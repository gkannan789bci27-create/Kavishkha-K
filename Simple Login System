#include <stdio.h>
#include <string.h>

int main() {
    char username[20];
    char password[20];
    char correct_user[] = "admin";
    char correct_pass[] = "12345";

    printf("--- SYSTEM LOGIN ---\n");
    
    printf("Enter Username: ");
    scanf("%s", username);

    printf("Enter Password: ");
    scanf("%s", password); 
    /* Note: In advanced versions, we use special functions 
       to print '*' instead of actual letters */

    // strcmp returns 0 if strings match
    if (strcmp(username, correct_user) == 0 && strcmp(password, correct_pass) == 0) {
        printf("\nLogin Successful! Welcome, %s.\n", username);
    } else {
        printf("\nAccess Denied. Incorrect username or password.\n");
    }

    return 0;
}
