#include <stdio.h>

int main() {
    char sentence[1000];
    FILE *fptr;

    fptr = fopen("program.txt", "w");
    if (fptr == NULL) {
        printf("Error!");
        return 1;
    }

    printf("Enter a sentence: ");
    fgets(sentence, sizeof(sentence), stdin);
    fprintf(fptr, "%s", sentence);
    fclose(fptr);

    printf("Data saved to program.txt\n");
    return 0;
}
