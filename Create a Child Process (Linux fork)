#include <stdio.h>
#include <unistd.h>

int main() {
    int pid = fork();

    if (pid == 0) {
        printf("I am the child process (PID: %d)\n", getpid());
    } else if (pid > 0) {
        printf("I am the parent process (PID: %d)\n", getpid());
    } else {
        printf("Fork failed!\n");
    }

    return 0;
}
