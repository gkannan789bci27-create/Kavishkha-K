#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int guess, number, attempts = 0;
    srand(time(0)); // Seed random number generator
    number = rand() % 100 + 1; // Random number between 1 and 100

    printf("I have chosen a number between 1 and 100. Guess it!\n");

    do {
        printf("Enter your guess: ");
        scanf("%d", &guess);
        attempts++;

        if (guess > number) printf("Lower!\n");
        else if (guess < number) printf("Higher!\n");
        else printf("Correct! You got it in %d attempts.\n", attempts);
    } while (guess != number);

    return 0;
}
