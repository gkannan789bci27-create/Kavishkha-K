#include <stdio.h>
#define SIZE 5

int items[SIZE], front = -1, rear = -1;

void enQueue(int value) {
    if (rear == SIZE - 1) printf("Queue is Full\n");
    else {
        if (front == -1) front = 0;
        items[++rear] = value;
        printf("Inserted %d\n", value);
    }
}

int main() {
    enQueue(10); enQueue(20); enQueue(30);
    printf("Front element is %d\n", items[front]);
    return 0;
}
